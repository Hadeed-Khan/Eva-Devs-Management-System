<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bodyColor"
    tools:context=".Activities.ActivityAddCourse">

    <ImageView
        android:layout_width="30dp"
        android:layout_height="30dp"
        app:layout_constraintTop_toTopOf="@+id/header_Title"
        app:layout_constraintBottom_toBottomOf="@+id/header_Title"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="#fff"
        android:src="@drawable/left_arrow"
        android:elevation="1dp"
        android:layout_marginTop="35dp"
        android:layout_marginStart="10dp"
        android:id="@+id/backActivityIV"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="90dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@color/blue"
        android:text="AVAILBLE COURSES"
        android:gravity="center"
        android:textSize="27sp"
        android:textColor="#fff"
        android:textStyle="bold"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="35dp"
        android:id="@+id/header_Title"
        />

    <androidx.cardview.widget.CardView
        android:id="@+id/toolbar"
        app:cardElevation="3dp"
        app:cardUseCompatPadding="true"
        app:cardCornerRadius="6dp"
        app:layout_constraintTop_toBottomOf="@+id/header_Title"
        android:layout_width="match_parent"
        android:layout_height="240dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <EditText
                android:layout_width="300dp"
                android:layout_height="50dp"
                android:inputType="text"
                android:imeOptions="actionDone"
                android:hint="Search Course Name,Fee"
                android:background="@drawable/bg_input"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:paddingHorizontal="10dp"
                android:id="@+id/searchCourseET"
                android:textColor="#000"
                android:layout_marginTop="4dp"
                />

            <TextView
                android:layout_marginTop="3dp"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fee Sorting"
                app:layout_constraintTop_toBottomOf="@id/searchCourseET"
                android:textStyle="bold"
                android:textColor="#000"
                android:id="@+id/sortingText"
                />

            <Spinner
                android:entries="@array/CourseFee_Sorting"
                android:layout_width="300dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                app:layout_constraintTop_toBottomOf="@id/sortingText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp"
                android:id="@+id/feeSortingSP"
                />


            <TextView
                android:layout_marginTop="3dp"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filter Course Duration"
                app:layout_constraintTop_toBottomOf="@id/feeSortingSP"
                android:textStyle="bold"
                android:textColor="#000"
                android:id="@+id/courseDurationT"
                />

            <Spinner
                android:layout_width="300dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                app:layout_constraintTop_toBottomOf="@id/courseDurationT"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp"
                android:id="@+id/courseDurationSP"
                />



        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="400dp"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        android:padding="4dp"
        android:layout_marginTop="5dp"
        android:id="@+id/courseRecyclerView"
        />

    <TextView
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No Data Found"
        android:id="@+id/noDataFound"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:gravity="center"
        android:fontFamily="casual"
        android:textSize="20dp"
        android:textColor="#000"
        />



    <ImageView
        android:id="@+id/addCourseIV"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_margin="30dp"
        android:background="@drawable/bg_addbt"
        android:padding="5dp"
        android:src="@drawable/ic_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="#fff" />




</androidx.constraintlayout.widget.ConstraintLayout>