<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="7dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/bg_attendance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="70dp"
        android:layout_margin="2dp"
        app:layout_constraintTop_toTopOf="parent"
        >
        <TextView
            android:id="@+id/idTV"
            app:layout_constraintWidth_percent="0.15"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="0dp"
            android:text="1:"
            android:fontFamily="@font/roboto_condensed_blackitalic"
            android:paddingStart="6dp"
            android:textColor="#000"
            android:textSize="17sp"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Ali Khan"
            android:textSize="17sp"
            android:textColor="#000"
            android:fontFamily="@font/roboto_regular"
            android:id="@+id/studentNameTV"
            android:gravity="center"
            app:layout_constraintWidth_percent="0.45"
            app:layout_constraintStart_toEndOf="@id/idTV"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Khan"
            android:textSize="17sp"
            android:textColor="#000"
            android:id="@+id/stdFNameTV"
            android:gravity="center"
            android:fontFamily="@font/roboto_light"
            app:layout_constraintWidth_percent="0.40"
            app:layout_constraintStart_toEndOf="@id/studentNameTV"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/line"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.98"
            app:layout_constraintTop_toBottomOf="@+id/studentNameTV"
            android:layout_width="0dp"
            android:background="@drawable/bg_container"
            android:layout_height="1dp"/>


        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/line"
            android:id="@+id/radioGroup"
            android:orientation="horizontal"
            android:gravity="center"
            >
            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Present"
                android:buttonTint="@color/blue"
                android:textSize="18sp"
                android:layout_marginEnd="20dp"
                android:id="@+id/presentButton"
                />
            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Absent"
                android:buttonTint="@color/blue"
                android:textSize="18sp"
                android:layout_marginEnd="20dp"
                android:id="@+id/absentButton"
                android:checked="true"
                />
            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Leave"
                android:buttonTint="@color/blue"
                android:textSize="18sp"
                android:id="@+id/leaveButton"
                />



        </RadioGroup>

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>