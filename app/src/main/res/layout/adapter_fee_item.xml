<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_card">

    <TextView
        android:id="@+id/stdNameTV"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="John Doe"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0A0A0A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/feeTypeTV"/>

    <TextView
        android:id="@+id/feeTypeTV"
        android:layout_width="130dp"
        android:layout_height="20dp"
        android:text="Admission"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:textSize="11sp"
        android:background="@drawable/bg_button"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/courseNameTV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Computer Science"
        android:textColor="#706666"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/stdNameTV"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/line"
        android:layout_width="330dp"
        android:layout_height="1dp"
       android:background="@drawable/bg_container"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/courseNameTV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>


    <LinearLayout
        android:id="@+id/llFees"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/courseNameTV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/TotalfeeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Fee"
                android:textColor="#888888"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/totalAmountTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 25,000"
                android:textSize="16sp"
                android:textColor="#0A0A0A"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Paid -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/PaidLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paid"
                android:textColor="#888888"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/paidAmountTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 10,000"
                android:textSize="16sp"
                android:textColor="#28A745"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Remaining -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/RemainingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remaining"
                android:textColor="#888888"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/remainingAmountTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 15,000"
                android:textSize="16sp"
                android:textColor="#FF0000"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:progressDrawable="@drawable/progress_bg_green"
        android:id="@+id/progressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="20dp"
        android:max="100"
        android:progress="70"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/llFees"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:clipToOutline="true"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:textStyle="bold"
        android:textColor="@color/white"
        android:text="45%"
        app:layout_constraintBottom_toBottomOf="@id/progressBar"
        app:layout_constraintEnd_toEndOf="@id/progressBar"
        app:layout_constraintStart_toStartOf="@id/progressBar"
        app:layout_constraintTop_toTopOf="@id/progressBar"
        android:id="@+id/progressPercentangeTV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/line2"
        android:layout_width="330dp"
        android:layout_height="1dp"
        android:background="@drawable/bg_container"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"/>

    <!-- Payment Date -->
    <TextView
        android:id="@+id/paymentDatelabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment Date:"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/line2"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/paymentDateTV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="05 Feb 2026"
        android:textColor="#2E2929"
        android:textStyle="bold"
        android:textSize="12sp"
        android:layout_marginStart="3dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/line2"
        app:layout_constraintStart_toEndOf="@id/paymentDatelabel"/>

</androidx.constraintlayout.widget.ConstraintLayout>
