<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:cardCornerRadius="10dp"
        app:cardElevation="8dp"
        app:cardUseCompatPadding="true"
        >
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:background="#81EEF0F1"
            android:layout_height="match_parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/containerHead"
                android:background="#fff"
                android:padding="10dp"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_height="wrap_content">

                <ImageView
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    app:layout_constraintStart_toStartOf="parent"
                    android:src="@drawable/id_card"
                    android:id="@+id/cardImage"
                    app:tint="#2196F3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardImage"
                    android:text="Enrollment ID:"
                    android:id="@+id/enrollTextH"
                    android:paddingStart="4dp"
                    android:textColor="#000"
                    android:textSize="15sp"
                    />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/enrollTextH"
                    android:text="234"
                    android:id="@+id/enrollIdTV"
                    android:paddingStart="8dp"
                    android:textColor="#000"
                    android:textSize="16sp"
                    />


                <ImageView
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    app:layout_constraintStart_toEndOf="@id/enrollIdTV"
                    android:src="@drawable/book"
                    android:id="@+id/courseImage"
                    android:layout_marginStart="45dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/courseImage"
                    android:text="Course ID:"
                    android:id="@+id/courseIdText"
                    android:paddingStart="4dp"
                    android:textColor="#000"
                    android:textSize="15sp"
                    />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/courseIdText"
                    android:text="140"
                    android:id="@+id/courseIdTV"
                    android:paddingStart="8dp"
                    android:textColor="#000"
                    android:textSize="15sp"
                    />

                <TextView
                    android:layout_width="1dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                   app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:background="#1B000000"
                    android:id="@+id/line"
                    />


            </androidx.constraintlayout.widget.ConstraintLayout>

<androidx.constraintlayout.widget.ConstraintLayout
    app:layout_constraintTop_toBottomOf="@id/containerHead"
    android:layout_width="match_parent"
    android:padding="4dp"
    android:id="@+id/studentInfoContainer"
    android:layout_height="wrap_content">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:text="Student Info"
        android:textColor="#2196F3"
        android:textStyle="bold"
        android:textSize="15sp"
        android:id="@+id/studentInfo"
        />
    <TextView
        android:layout_marginStart="6dp"
        android:layout_width="290dp"
        android:layout_height="1dp"
        app:layout_constraintStart_toEndOf="@id/studentInfo"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="10dp"
        android:background="#74A5A6A8"
        />

    <ImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        app:layout_constraintTop_toBottomOf="@id/studentInfo"
        app:layout_constraintStart_toStartOf="parent"
        android:src="@drawable/user"
        android:layout_marginTop="10dp"
        app:tint="#4CAF50"
        android:id="@+id/userImage"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/userImage"
        app:layout_constraintTop_toBottomOf="@id/studentInfo"
        android:text="Student ID:"
        android:layout_marginTop="10dp"
        android:textColor="#D7000000"
        android:layout_marginStart="4dp"
        android:textSize="11dp"
        android:id="@+id/studentId"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/studentId"
        app:layout_constraintTop_toBottomOf="@id/studentInfo"
        android:text="132"
        android:layout_marginTop="10dp"
        android:id="@+id/studentIdTV"
        android:textColor="#000"
        android:layout_marginStart="2dp"
        android:textSize="11dp"
        />


    <ImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        app:layout_constraintTop_toBottomOf="@id/userImage"
        app:layout_constraintStart_toStartOf="parent"
        android:src="@drawable/user"
        android:layout_marginTop="10dp"
        app:tint="#2196F3"
        android:id="@+id/userImage2"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/userImage"
        app:layout_constraintTop_toBottomOf="@id/studentId"
        android:text="Name:"
        android:layout_marginTop="10dp"
        android:textColor="#D7000000"
        android:layout_marginStart="4dp"
        android:textSize="11dp"
        android:id="@+id/studentName"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/studentName"
        app:layout_constraintTop_toBottomOf="@id/studentId"
        android:text="Ali Khan"
        android:layout_marginTop="10dp"
        android:id="@+id/studentNameTV"
        android:textColor="#000"
        android:layout_marginStart="3dp"
        android:textSize="11dp"
        />

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        app:layout_constraintTop_toBottomOf="@id/userImage2"
        app:layout_constraintStart_toStartOf="parent"
        android:src="@drawable/parent_icon"
        android:layout_marginTop="10dp"
        android:id="@+id/fatherImage"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/fatherImage"
        app:layout_constraintTop_toBottomOf="@id/studentName"
        android:text="Father's Name:"
        android:layout_marginTop="10dp"
        android:textColor="#D7000000"
        android:layout_marginStart="2dp"
        android:textSize="10dp"
        android:id="@+id/studentFName"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/studentFName"
        app:layout_constraintTop_toBottomOf="@id/studentNameTV"
        android:text="Nawaz Khan"
        android:layout_marginTop="10dp"
        android:id="@+id/studentFNameTV"
        android:paddingBottom="3dp"
        android:textColor="#000"
        android:layout_marginStart="2dp"
        android:textSize="10dp"
        />

    <TextView
        android:layout_width="0.8dp"
        android:layout_height="100dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/studentInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#1B000000"
        android:id="@+id/line2"
        android:layout_marginTop="10dp"
        />

    <ImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        app:layout_constraintTop_toBottomOf="@id/studentInfo"
        app:layout_constraintStart_toEndOf="@+id/line2"
        android:src="@drawable/mortarboard"
        android:layout_marginTop="10dp"
        app:tint="#2196F3"
        android:layout_marginStart="4dp"
        android:id="@+id/courseInfoImage"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/courseInfoImage"
        app:layout_constraintTop_toBottomOf="@id/studentInfo"
        android:text="Course Info"
        android:layout_marginTop="10dp"
        android:textColor="#2196F3"
        android:textStyle="bold"
        android:layout_marginStart="8dp"
        android:textSize="12dp"
        android:paddingBottom="8dp"
        android:id="@+id/courseInfoText"
        />


    <ImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        app:layout_constraintTop_toBottomOf="@id/courseInfoImage"
        app:layout_constraintStart_toEndOf="@+id/line2"
        android:src="@drawable/curriculum"
        android:layout_marginTop="1dp"
        app:tint="#2196F3"
        android:layout_marginStart="4dp"
        android:id="@+id/courseNameImage"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/courseNameImage"
        app:layout_constraintTop_toBottomOf="@id/courseInfoText"
        android:text="Course:"
        android:textColor="#A9000000"
        android:layout_marginStart="2dp"
        android:textSize="10dp"
        android:id="@+id/courseName"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="22dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/courseName"
        app:layout_constraintTop_toBottomOf="@id/courseInfoText"
        android:text="SEO"
        android:id="@+id/courseNameTV"
        android:textColor="#000"
        android:layout_marginStart="2dp"
        android:textSize="8dp"
        />

    <ImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        app:layout_constraintTop_toBottomOf="@id/courseNameTV"
        app:layout_constraintStart_toEndOf="@+id/line2"
        android:src="@drawable/clock"
        android:layout_marginTop="4dp"
        android:id="@+id/durationImage"
        android:layout_marginStart="4dp"
        android:padding="1dp"
        app:tint="#2196F3" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/durationImage"
        app:layout_constraintTop_toBottomOf="@id/courseNameTV"
        android:text= "Duration:"
        android:textColor="#A9000000"
        android:layout_marginStart="4dp"
        android:paddingTop="6dp"
        android:textSize="11sp"
        android:id="@+id/courseDurationText"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/courseDurationText"
        app:layout_constraintTop_toBottomOf="@id/courseNameTV"
        android:text="3 Months"
        android:id="@+id/courseDurationTV"
        android:textColor="#000"
        android:paddingTop="6dp"
        android:layout_marginStart="3dp"
        android:textSize="11sp"
        />

    <ImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        app:layout_constraintTop_toBottomOf="@id/courseDurationText"
        app:layout_constraintStart_toEndOf="@+id/line2"
        android:src="@drawable/calendar"
        android:layout_marginTop="4dp"
        android:id="@+id/enrollmentDateImage"
        android:layout_marginStart="4dp"
        android:padding="1dp"
        app:tint="#FF9800" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/enrollmentDateImage"
        app:layout_constraintTop_toBottomOf="@id/courseDurationText"
        android:text= "Enrollment Date:"
        android:textColor="#A9000000"
        android:layout_marginStart="4dp"
        android:paddingTop="6dp"
        android:textSize="11dp"
        android:id="@+id/enrollDateText"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/enrollDateText"
        app:layout_constraintTop_toBottomOf="@id/courseDurationText"
        android:text="04/02/2026"
        android:id="@+id/enrollDateTV"
        android:textColor="#000"
        android:paddingTop="6dp"
        android:paddingStart="2dp"
        android:textSize="9dp"
        />

</androidx.constraintlayout.widget.ConstraintLayout>

<androidx.constraintlayout.widget.ConstraintLayout
    app:layout_constraintTop_toBottomOf="@id/studentInfoContainer"
    android:layout_width="match_parent"
    android:background="#fff"
    android:paddingVertical="10dp"
    android:layout_height="wrap_content">

    <ImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:src="@drawable/calendar"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="4dp"
        android:id="@+id/enrollmentDateImage2"
        android:layout_marginStart="4dp"
        android:padding="1dp"
        app:tint="#3F51B5" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/enrollmentDateImage2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:text= "Enrollment Date:"
        android:textColor="#A9000000"
        android:layout_marginStart="4dp"
        android:paddingTop="5dp"
        android:textSize="11dp"
        android:id="@+id/enrollDateText2"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/enrollDateText2"
        app:layout_constraintTop_toTopOf="parent"
        android:text="04/02/2026"
        app:layout_constraintBottom_toBottomOf="parent"
        android:id="@+id/enrollDateTV2"
        android:textColor="#000"
        android:paddingTop="5dp"
        android:layout_marginStart="3dp"
        android:paddingStart="2dp"
        android:textSize="11dp"
        />

    <TextView
        android:layout_width="1dp"
        android:layout_height="32dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#1B000000"
        android:id="@+id/line3"
        android:layout_marginStart="20dp"
        />


    <ImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/line3"
        android:src="@drawable/clock"
        android:layout_marginTop="4dp"
        android:id="@+id/durationImage2"
        android:layout_marginStart="8dp"
        android:padding="1dp"
        app:tint="#2196F3" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="25dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/durationImage2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:text= "Duration:"
        android:paddingTop="3dp"
        android:textColor="#A9000000"
        android:layout_marginStart="5dp"
        android:textSize="11dp"
        android:id="@+id/courseDurationText2"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/courseDurationText2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:text="3 Months"
        android:id="@+id/courseDurationTV2"
        android:textColor="#000"
        android:paddingTop="3dp"
        android:layout_marginStart="8dp"
        android:textSize="12dp"
        />


</androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>