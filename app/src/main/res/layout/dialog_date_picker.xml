<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:minHeight="300dp">

    <androidx.cardview.widget.CardView
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        app:cardCornerRadius="10dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true"
        android:layout_height="320dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="match_parent"
                android:gravity="center"
                android:text="Select Date"
                android:textColor="#000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:id="@+id/dateLebel"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                />

            <DatePicker
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:calendarViewShown="false"
                android:datePickerMode="spinner"
                android:layout_marginTop="10dp"
                android:id="@+id/filterDateDP"
                app:layout_constraintTop_toBottomOf="@+id/dateLebel"
                />

            <Button
                android:layout_width="120dp"
                android:layout_height="40dp"
                app:layout_constraintTop_toBottomOf="@+id/filterDateDP"
                app:layout_constraintEnd_toEndOf="parent"
                android:background="@drawable/bg_addstudent_bt"
                android:text="Apply"
                android:gravity="center"
                android:textColor="#fff"
                android:layout_marginEnd="20dp"
                android:id="@+id/selectDateBT"
                android:textStyle="bold"
                android:textSize="24sp"
                />
            <Button
                android:layout_width="120dp"
                android:layout_height="40dp"
                app:layout_constraintTop_toBottomOf="@+id/filterDateDP"
                app:layout_constraintEnd_toStartOf="@+id/selectDateBT"
                android:background="@drawable/bg_cancel_bt"
                android:text="Cancel"
                android:id="@+id/cancelDialogBT"
                android:gravity="center"
                android:textColor="#000"
                android:textStyle="bold"
                android:textSize="24sp"
                android:layout_marginEnd="20dp"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>


</androidx.constraintlayout.widget.ConstraintLayout>