<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="350dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="90dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/bg_card1"
        android:text="SETTING"
        android:gravity="center"
        android:textSize="30sp"
        android:textColor="#fff"
        android:textStyle="bold"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="20dp"
        android:id="@+id/header_Title"
        />


    <Button
        android:layout_width="200dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/header_Title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_addstudent_bt"
        android:text="Change Password"
        android:gravity="center"
        android:textColor="#fff"
        android:id="@+id/changePassWordBT"
        android:textSize="20sp"
        android:fontFamily="@font/roboto_medium"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="Logout"
        android:textColor="#000"
        android:id="@+id/logoutText"
        android:textSize="20sp"
        android:fontFamily="@font/roboto_medium"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/changePassWordBT"
        />

    <ImageView
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:src="@drawable/logout"
        android:padding="6dp"
        app:layout_constraintTop_toBottomOf="@id/logoutText"
        android:background="@drawable/bg_addstudent_bt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:id="@+id/logoutIV"
        app:tint="#fff" />

    <Button
        android:layout_width="150dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/logoutIV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_cancel_bt"
        android:text="CANCEL"
        android:gravity="center"
        android:textColor="#000"
        android:id="@+id/cancelDialogBT"
        android:textSize="20sp"
        android:fontFamily="@font/roboto_medium"
        />




</androidx.constraintlayout.widget.ConstraintLayout>