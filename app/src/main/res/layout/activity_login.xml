<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="@drawable/background"
    android:layout_height="match_parent"
    tools:context=".Activities.ActivityLogin">


    <ImageView
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:src="@drawable/logo"
        app:layout_constraintBottom_toTopOf="@id/header_Title"
        android:background="@drawable/bg_logo"
        android:clipToOutline="true"
        />


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:text="LOGIN"
        android:layout_marginTop="90dp"
        android:gravity="center"
        android:textSize="38sp"
        android:textColor="#fff"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="10dp"
        android:id="@+id/header_Title"
        />



<androidx.cardview.widget.CardView
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    android:layout_width="match_parent"
    app:cardUseCompatPadding="true"
    app:cardCornerRadius="7dp"
    android:layout_margin="4dp"
    app:cardElevation="4dp"
    android:layout_height="270dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="25dp"
            android:layout_height="25dp"
            app:layout_constraintTop_toTopOf="@id/userNameET"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/userNameET"
            android:src="@drawable/user"
            android:id="@+id/userImage"
            android:layout_marginStart="12dp"
            app:tint="#253C47" />

    <EditText
        android:hint="User name"
        android:background="@drawable/bg_input"
        android:id="@+id/userNameET"
        android:paddingHorizontal="10dp"
        app:layout_constraintStart_toEndOf="@id/userImage"
        android:layout_marginStart="7dp"
        android:layout_marginTop="10dp"
        android:textColor="#000"
        android:inputType="text"
        android:imeOptions="actionNext"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="290dp"
        android:layout_height="55dp"/>

    <EditText
        android:hint="Password"
        android:id="@+id/passwordET"
        app:layout_constraintStart_toEndOf="@+id/passImage"
        android:layout_marginStart="7dp"
        app:layout_constraintTop_toBottomOf="@id/userNameET"
        android:layout_width="290dp"
        android:paddingHorizontal="10dp"
        android:textColor="#000"
        android:inputType="textPassword"
        android:imeOptions="actionDone"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_input"
        android:layout_height="55dp"/>

        <ImageView
            android:layout_width="25dp"
            android:layout_height="25dp"
            app:layout_constraintTop_toTopOf="@id/passwordET"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/passwordET"
            android:src="@drawable/lock"
            android:id="@+id/passImage"
            android:layout_marginStart="12dp"
            app:tint="#253C47" />

        <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            app:layout_constraintTop_toBottomOf="@+id/passwordET"
            app:layout_constraintStart_toStartOf="parent"
            android:text="Remember Me"
            android:id="@+id/rememberMeCB"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@+id/loginBT"
            app:layout_constraintStart_toStartOf="parent"
            android:text="User Name Or Password Invalid"
            android:textColor="#DD0E0E"
            android:visibility="gone"
            android:layout_marginStart="10dp"
            android:layout_marginTop="8dp"
            android:id="@+id/passIncorrect"
            />

    <Button
        android:id="@+id/loginBT"
        android:textColor="#fff"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="8dp"
        android:text="Login"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/bg_addstudent_bt"
        android:gravity="center"
        android:textSize="23sp"
        android:fontFamily="@font/roboto_medium"
        android:layout_width="150dp"
        android:layout_height="50dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>


</androidx.constraintlayout.widget.ConstraintLayout>