<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="@color/bodyColor"
    android:layout_height="match_parent"
    tools:context=".Activities.ActivityAddFee">

    <ImageView
        android:layout_width="30dp"
        android:layout_height="30dp"
        app:layout_constraintTop_toTopOf="@+id/header_Title"
        app:layout_constraintBottom_toBottomOf="@+id/header_Title"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="#fff"
        android:src="@drawable/left_arrow"
        android:elevation="1dp"
        android:layout_marginTop="35dp"
        android:layout_marginStart="10dp"
        android:id="@+id/backActivityIV"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="90dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@color/blue"
        android:text="ADD FEE RECORD"
        android:gravity="center"
        android:textSize="27sp"
        android:textColor="#fff"
        android:textStyle="bold"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="35dp"
        android:id="@+id/header_Title"
        />

<androidx.core.widget.NestedScrollView
    app:layout_constraintTop_toBottomOf="@id/header_Title"
    android:layout_width="match_parent"
    android:layout_height="660dp">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


    <Button
        android:id="@+id/chooseStdBT"
        app:layout_constraintTop_toTopOf="parent"
        android:textColor="@color/white"
        android:background="@drawable/bg_addstudent_bt"
        android:text="Choose Student"
        android:layout_width="150dp"
        android:fontFamily="@font/roboto_light"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:gravity="center"
        android:textSize="18sp"
        android:layout_marginTop="20dp"
        android:layout_height="50dp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:visibility="gone"
        android:id="@+id/containerStd"
        android:background="#36F0F6F6"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/chooseStdBT"
        android:layout_width="match_parent"
        android:layout_height="200dp">

        <EditText
            android:paddingStart="8dp"
            android:background="@drawable/bg_input"
            android:hint="Search Student"
            android:inputType="text"
            android:imeOptions="actionDone"
            app:layout_constraintTop_toTopOf="parent"
            android:id="@+id/searchStdET"
            android:layout_width="match_parent"
            android:layout_height="40dp"/>

        <TextView
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No Data Found"
            android:id="@+id/noDataFound"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:gravity="center"
            android:fontFamily="casual"
            android:textSize="16dp"
            android:textColor="#000"
            />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerStd"
            android:background="#fff"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/searchStdET"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <Button
        android:id="@+id/chooseCourseBT"
        app:layout_constraintTop_toBottomOf="@id/containerStd"
        android:textColor="@color/white"
        android:text="Choose Course"
        android:background="@drawable/bg_addstudent_bt"
        android:layout_width="150dp"
        android:gravity="center"
        android:fontFamily="@font/roboto_light"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:textSize="18sp"
        android:layout_height="50dp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
     android:visibility="gone"
        android:id="@+id/containerCourse"
        android:background="#36F0F6F6"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/chooseCourseBT"
        android:layout_width="match_parent"
        android:layout_height="200dp">


        <EditText
            android:paddingHorizontal="10dp"
            android:background="@drawable/bg_input"
            android:hint="Search Course"
            android:inputType="text"
            android:imeOptions="actionDone"
            app:layout_constraintTop_toTopOf="parent"
            android:id="@+id/searchCourseET"
            android:layout_width="match_parent"
            android:layout_height="40dp"/>

        <TextView
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No Data Found"
            android:id="@+id/noDataFound2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:gravity="center"
            android:fontFamily="casual"
            android:textSize="16dp"
            android:textColor="#000"
            />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerCourse"
            android:background="#fff"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/searchCourseET"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/containerCourse"
        app:layout_constraintStart_toStartOf="parent"
        android:text="Fee Type"
        android:textColor="#000"
        android:fontFamily="@font/roboto_medium"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_marginStart="30dp"
        android:id="@+id/feeTypeTV"
        />
    <Spinner
        android:layout_width="300dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/feeTypeTV"
        android:layout_height="50dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_input"
        android:entries="@array/fee_type"
        android:id="@+id/feeTypeSP"
        />

    <DatePicker
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/feeTypeSP"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:datePickerMode="spinner"
        android:calendarViewShown="false"
        android:id="@+id/monthFeeDP"
        />


    <EditText
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:background="@drawable/bg_input"
        app:layout_constraintTop_toBottomOf="@id/monthFeeDP"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:hint="Paid Amount"
        android:inputType="number"
        android:imeOptions="actionDone"
        android:id="@+id/feePaidET"
        android:paddingHorizontal="10dp"
        />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/feePaidET"
            app:layout_constraintStart_toStartOf="parent"
            android:text="Payment Date"
            android:textColor="#000"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginStart="30dp"
            android:id="@+id/paymentDateTV"
            />

    <DatePicker
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/paymentDateTV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:datePickerMode="spinner"
        android:calendarViewShown="false"
        android:id="@+id/dateDP"
        />
    <androidx.cardview.widget.CardView
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        app:layout_constraintTop_toBottomOf="@id/dateDP"
        app:cardCornerRadius="8dp"
        android:layout_margin="10dp"
        app:cardElevation="2dp"
        android:id="@+id/selectedCard"
        >
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selected Student"
                app:layout_constraintTop_toTopOf="parent"
                android:gravity="center"
                android:textColor="#000"
                android:textSize="12dp"
                android:textStyle="bold"
                android:id="@+id/selectedStudentlebel"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/selectedStudentlebel"
                app:layout_constraintStart_toStartOf="parent"
                android:textColor="#000"
                android:paddingStart="6dp"
                android:id="@+id/stdIdTV"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/selectedStudentlebel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:textColor="#000"
                android:id="@+id/stdNameTV"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/selectedStudentlebel"
                app:layout_constraintEnd_toEndOf="parent"
                android:textColor="#000"
                android:paddingEnd="6dp"
                android:id="@+id/stdFNameTV"
                />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selected Course"
                app:layout_constraintTop_toBottomOf="@+id/stdFNameTV"
                android:gravity="center"
                android:textColor="#000"
                android:textSize="12dp"
                android:textStyle="bold"
                android:id="@+id/selectedCourselebel"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/selectedCourselebel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:textColor="#000"
                android:id="@+id/courseNameTV"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.cardview.widget.CardView>
    <Button
        android:layout_width="150dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/selectedCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/bg_addstudent_bt"
        android:text="ADD"
        android:layout_marginTop="10dp"
        android:textColor="#fff"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="23sp"
        android:id="@+id/addFeeBT"
        />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>