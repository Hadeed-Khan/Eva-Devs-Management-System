<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:minHeight="300dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">



    <androidx.cardview.widget.CardView
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="match_parent"
        app:cardUseCompatPadding="true"
        app:cardCornerRadius="7dp"
        android:layout_margin="2dp"
        app:cardElevation="4dp"
        android:layout_height="240dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                app:layout_constraintTop_toTopOf="@id/userNameET"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="@+id/userNameET"
                android:src="@drawable/user"
                android:id="@+id/userImage"
                android:layout_marginStart="12dp"
                app:tint="#253C47" />

            <EditText
                android:hint="New User name"
                android:background="@drawable/bg_input"
                android:id="@+id/userNameET"
                android:paddingHorizontal="10dp"
                app:layout_constraintStart_toEndOf="@id/userImage"
                android:layout_marginStart="7dp"
                android:layout_marginTop="10dp"
                android:textColor="#000"
                android:inputType="text"
                android:imeOptions="actionNext"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_width="270dp"
                android:layout_height="50dp"/>

            <EditText
                android:hint="New Password"
                android:id="@+id/passwordET"
                app:layout_constraintStart_toEndOf="@+id/passImage"
                android:layout_marginStart="7dp"
                app:layout_constraintTop_toBottomOf="@id/userNameET"
                android:layout_width="270dp"
                android:paddingHorizontal="10dp"
                android:textColor="#000"
                android:inputType="textPassword"
                android:imeOptions="actionDone"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_input"
                android:layout_height="50dp"/>

            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                app:layout_constraintTop_toTopOf="@id/passwordET"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="@+id/passwordET"
                android:src="@drawable/lock"
                android:id="@+id/passImage"
                android:layout_marginStart="12dp"
                app:tint="#253C47" />

            <Button
                android:id="@+id/cancelDialogBT"
                android:textColor="#000"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="10dp"
                android:text="Cancel"
                android:layout_marginEnd="10dp"
                app:layout_constraintEnd_toStartOf="@+id/updateBT"
                android:background="@drawable/bg_cancel_bt"
                android:gravity="center"
                android:textSize="23sp"
                android:fontFamily="@font/roboto_medium"
                android:layout_width="120dp"
                android:layout_height="50dp"/>

            <Button
                android:id="@+id/updateBT"
                android:textColor="#fff"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="10dp"
                android:text="Update"
                android:layout_marginEnd="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                android:background="@drawable/bg_addstudent_bt"
                android:gravity="center"
                android:textSize="23sp"
                android:fontFamily="@font/roboto_medium"
                android:layout_width="150dp"
                android:layout_height="50dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>


</androidx.constraintlayout.widget.ConstraintLayout>