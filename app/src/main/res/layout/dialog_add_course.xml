<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:minHeight="400dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        app:layout_constraintTop_toTopOf="parent"
        app:cardCornerRadius="10dp"
        app:cardElevation="4dp"
        android:layout_width="match_parent"
        android:layout_height="390dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

    <TextView
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="ADD COURSE"
        android:gravity="center"
        android:textColor="#fff"
        android:background="@color/blue"
        android:textSize="30sp"
        android:textStyle="bold"
        android:fontFamily="@font/roboto_medium"
        android:id="@+id/dialogHeader"
        />


    <EditText
        android:layout_width="300dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/dialogHeader"
        android:hint="Course Name"
        android:paddingHorizontal="10dp"
        android:textColor="#000"
        android:background="@drawable/bg_input"
        android:layout_marginTop="10dp"
        android:id="@+id/courseNameET"
        android:imeOptions="actionNext"
        android:inputType="text"
        />

    <EditText
        android:layout_width="300dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/courseNameET"
        android:hint="Course Fee"
        android:paddingHorizontal="10dp"
        android:textColor="#000"
        android:background="@drawable/bg_input"
        android:layout_marginTop="10dp"
        android:id="@+id/courseFeeET"
        android:imeOptions="actionDone"
        android:inputType="number"
        />

    <TextView
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Course Duration"
        app:layout_constraintTop_toBottomOf="@id/courseFeeET"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="10dp"
        android:layout_marginTop="8dp"
        android:textColor="#000"
        android:textSize="16sp"
        android:id="@+id/courseHint"
        />
    <Spinner
        android:layout_marginTop="5dp"
        android:layout_width="300dp"
        android:layout_height="55dp"
        app:layout_constraintTop_toBottomOf="@id/courseHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/bg_input"
        android:entries="@array/course_duration"
        android:id="@+id/courseDurationSP"
        />

    <Button
        android:layout_width="130dp"
        android:layout_height="45dp"
        app:layout_constraintTop_toBottomOf="@+id/courseDurationSP"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="25dp"
        android:text="ADD"
        android:textSize="24sp"
        android:textColor="#fff"
        android:fontFamily="monospace"
        android:background="@drawable/bg_addstudent_bt"
        android:gravity="center"
        android:id="@+id/addCourseBT"
        />

    <Button
        android:layout_width="130dp"
        android:layout_height="45dp"
        app:layout_constraintTop_toBottomOf="@+id/courseDurationSP"
        app:layout_constraintEnd_toStartOf="@id/addCourseBT"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="25dp"
        android:text="CANCEL"
        android:textSize="24sp"
        android:textColor="#000"
        android:fontFamily="monospace"
        android:background="@drawable/bg_cancel_bt"
        android:gravity="center"
        android:id="@+id/cancelDialogCBT"
        />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>