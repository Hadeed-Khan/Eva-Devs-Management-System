<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="@color/bodyColor"
    android:layout_height="match_parent"
    tools:context=".Activities.ActivityAddStudent">


    <ImageView
        android:layout_width="30dp"
        android:layout_height="30dp"
        app:layout_constraintTop_toTopOf="@+id/header_Title"
        app:layout_constraintBottom_toBottomOf="@+id/header_Title"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="#fff"
        android:src="@drawable/left_arrow"
        android:elevation="1dp"
        android:layout_marginTop="35dp"
        android:layout_marginStart="10dp"
android:id="@+id/backActivityIV"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="90dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/bg_card1"
        android:text="OUR STUDENTS"
        android:gravity="center"
        android:elevation="0dp"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#fff"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="35dp"
        android:id="@+id/header_Title"
        />

    <EditText
        android:layout_width="300dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/header_Title"
        android:id="@+id/searchStdET"
        android:imeOptions="actionDone"
        android:inputType="text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textSize="12dp"
        android:hint="Search Student Name , F Name , P.Number"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="10dp"
        android:layout_marginTop="10dp"
        android:textColor="#000"
        />
    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="620dp"
        app:layout_constraintTop_toBottomOf="@+id/searchStdET"
        android:padding="4dp"
        android:layout_marginTop="4dp"
        android:id="@+id/studentRecyclerView"
        />



    <TextView
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No Data Found"
        android:id="@+id/noDataFound"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:gravity="center"
        android:fontFamily="casual"
        android:textSize="20dp"
        android:textColor="#000"
        />
    <ImageView
        android:id="@+id/add_Student_IV"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_margin="30dp"
        android:background="@drawable/bg_addbt"
        android:padding="5dp"
        android:src="@drawable/ic_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="#fff" />

</androidx.constraintlayout.widget.ConstraintLayout>