<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:minHeight="440dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="445dp"
        app:layout_constraintTop_toTopOf="parent"
        app:cardCornerRadius="10dp"
        app:cardElevation="5dp"
        >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">


    <TextView
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="ADD STUDENT"
        android:gravity="center"
        android:textColor="#fff"
        android:background="@color/blue"
        android:textSize="30sp"
        android:textStyle="bold"
        android:fontFamily="@font/roboto_medium"
        android:id="@+id/dialogHeader"
        />


    <EditText
        android:layout_width="300dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/dialogHeader"
        android:hint="Student Name"
        android:paddingHorizontal="10dp"
        android:textColor="#000"
        android:background="@drawable/bg_input"
        android:layout_marginTop="10dp"
        android:id="@+id/studentNameET"
        android:imeOptions="actionNext"
        android:inputType="text"
        />

    <EditText
        android:layout_width="300dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/studentNameET"
        android:hint="Father Name"
        android:paddingHorizontal="10dp"
        android:textColor="#000"
        android:background="@drawable/bg_input"
        android:layout_marginTop="10dp"
        android:id="@+id/studentFatherNameET"
        android:imeOptions="actionNext"
        android:inputType="text"
        />

    <TextView
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Gender"
        app:layout_constraintTop_toBottomOf="@id/studentFatherNameET"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="10dp"
        android:layout_marginTop="8dp"
        android:textColor="#000"
        android:textSize="16sp"
        android:id="@+id/sHint"
        />

   <RadioGroup
       android:layout_width="300dp"
       android:layout_height="40dp"
       app:layout_constraintTop_toBottomOf="@id/sHint"
       app:layout_constraintStart_toStartOf="parent"
       app:layout_constraintEnd_toEndOf="parent"
       android:id="@+id/genderRadioGroup"
       android:orientation="horizontal"
       >

       <RadioButton
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:text="Male"
           android:buttonTint="@color/blue"
           android:textSize="18sp"
           android:id="@+id/maleButton"
           android:layout_marginEnd="30dp"
           />
       <RadioButton
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:text="Female"
           android:textSize="18sp"
           android:buttonTint="@color/blue"
           android:id="@+id/femaleButton"
           />


   </RadioGroup>

    <EditText
        android:layout_width="300dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/genderRadioGroup"
        android:hint="Contact Number"
        android:paddingHorizontal="10dp"
        android:textColor="#000"
        android:background="@drawable/bg_input"
        android:layout_marginTop="6dp"
        android:maxLength="11"
        android:id="@+id/studentNumberET"
        android:imeOptions="actionDone"
        android:inputType="phone"
        />

    <Button
        android:layout_width="130dp"
        android:layout_height="45dp"
        app:layout_constraintTop_toBottomOf="@+id/studentNumberET"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="20dp"
        android:text="ADD"
        android:textSize="24sp"
        android:textColor="#fff"
        android:fontFamily="monospace"
        android:background="@drawable/bg_addstudent_bt"
        android:gravity="center"
        android:id="@+id/addStudentBT"
        />

    <Button
        android:layout_width="130dp"
        android:layout_height="45dp"
        app:layout_constraintTop_toBottomOf="@+id/studentNumberET"
        app:layout_constraintEnd_toStartOf="@id/addStudentBT"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="20dp"
        android:text="CANCEL"
        android:textSize="24sp"
        android:textColor="#000"
        android:fontFamily="monospace"
        android:background="@drawable/bg_cancel_bt"
        android:gravity="center"
        android:id="@+id/cancelDialogBT"
        />


        </androidx.constraintlayout.widget.ConstraintLayout>



    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>