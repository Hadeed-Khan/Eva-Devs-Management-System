<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bodyColor"
    tools:context=".Activities.ActivityUpdateCourse">

    <ImageView
        android:layout_width="30dp"
        android:layout_height="30dp"
        app:layout_constraintTop_toTopOf="@+id/header_Title"
        app:layout_constraintBottom_toBottomOf="@+id/header_Title"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="#fff"
        android:src="@drawable/left_arrow"
        android:elevation="1dp"
        android:layout_marginTop="35dp"
        android:layout_marginStart="10dp"
        android:id="@+id/backActivityIV"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="90dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@color/blue"
        android:text="UPDATE COURSE"
        android:gravity="center"
        android:textSize="27sp"
        android:textColor="#fff"
        android:textStyle="bold"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="35dp"
        android:id="@+id/header_Title"
        />

    <EditText
        android:layout_width="310dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/header_Title"
        android:hint="Course Name"
        android:paddingHorizontal="10dp"
        android:textColor="#000"
        android:background="@drawable/bg_input"
        android:layout_marginTop="10dp"
        android:id="@+id/courseNameET"
        android:imeOptions="actionNext"
        android:inputType="text"
        />

    <EditText
        android:layout_width="310dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/courseNameET"
        android:hint="Course Fee"
        android:paddingHorizontal="10dp"
        android:textColor="#000"
        android:background="@drawable/bg_input"
        android:layout_marginTop="10dp"
        android:id="@+id/courseFeeET"
        android:imeOptions="actionDone"
        android:inputType="number"
        />

    <TextView
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Course Duration"
        app:layout_constraintTop_toBottomOf="@id/courseFeeET"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="10dp"
        android:layout_marginTop="8dp"
        android:textColor="#000"
        android:textSize="16sp"
        android:id="@+id/courseHint"
        />
    <Spinner
        android:layout_marginTop="5dp"
        android:layout_width="310dp"
        android:layout_height="55dp"
        app:layout_constraintTop_toBottomOf="@id/courseHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/bg_input"
        android:entries="@array/course_duration"
        android:id="@+id/courseDurationSP"
        />

    <Button
        android:layout_width="130dp"
        android:layout_height="45dp"
        app:layout_constraintTop_toBottomOf="@+id/courseDurationSP"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="25dp"
        android:text="UPDATE"
        android:textSize="24sp"
        android:textColor="#fff"
        android:fontFamily="monospace"
        android:background="@drawable/bg_addstudent_bt"
        android:gravity="center"
        android:id="@+id/updateCourseBT"
        />

    <Button
        android:layout_width="130dp"
        android:layout_height="45dp"
        app:layout_constraintTop_toBottomOf="@+id/courseDurationSP"
        app:layout_constraintEnd_toStartOf="@id/updateCourseBT"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="25dp"
        android:text="DELETE"
        android:textSize="24sp"
        android:textColor="#000"
        android:fontFamily="monospace"
        android:background="@drawable/bg_cancel_bt"
        android:gravity="center"
        android:id="@+id/deleteCourseBT"
        />



</androidx.constraintlayout.widget.ConstraintLayout>