<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_dialog"
    android:minHeight="160dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:text="Do You Really Want To Delete Enrollment ?"
        android:textColor="#4C4040"
        android:gravity="center"
        android:fontFamily="@font/roboto_medium"
        android:textSize="24dp"
        android:layout_marginTop="10dp"
        android:id="@+id/deleteText"
        />

    <Button
        android:layout_width="120dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/deleteText"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/bg_addstudent_bt"
        android:text="Delete"
        android:gravity="center"
        android:textColor="#fff"
        android:textSize="22dp"
        android:textStyle="bold"
        android:id="@+id/deleteEnrollmentBT"
        />
    <Button
        android:layout_width="120dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/deleteText"
        app:layout_constraintEnd_toStartOf="@+id/deleteEnrollmentBT"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/bg_cancel_bt"
        android:text="Cancel"
        android:gravity="center"
        android:textColor="#000"
        android:textSize="22dp"
        android:id="@+id/cancelDialogBT"
        />
</androidx.constraintlayout.widget.ConstraintLayout>